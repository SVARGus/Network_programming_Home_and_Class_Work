<Window x:Class="GourmetClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GourmetClient"
        xmlns:recipe="clr-namespace:GourmetRecipe"
        mc:Ignorable="d"
        Title="Recipe Search" Height="450" Width="800" MinWidth="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="SearchTextBox" Width="400" Height="25" VerticalAlignment="Center" ToolTip="Введите ингридиенты через запятую или название рецепта"/>
            <Button Content="Поиск" Width="100" Margin="10,0,0,0" x:Name="SearchButton" Click="SearchButton_Click"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="RecipesListBox" SelectionChanged="RecipeListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="1" Margin="10, 0,0,0" x:Name="RecipePanel">
                <TextBlock Text="Название:" FontWeight="Bold"/>
                <TextBlock Text="{Binding Name}" Margin="0,0,10,10"/>
                
                <TextBlock Text="Ингридиенты: " FontWeight="Bold"/>
                <TextBlock Text="{Binding IngredientsString}" TextWrapping="Wrap" Margin="0,0,10,10"/>
                
                <TextBlock Text="Инструкции:" FontWeight="Bold"/>
                <TextBlock Text="{Binding Instructions}" TextWrapping="Wrap" Margin="0,0,10,10"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
