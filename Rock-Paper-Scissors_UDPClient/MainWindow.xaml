<Window x:Class="Rock_Paper_Scissors_UDPClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rock_Paper_Scissors_UDPClient"
        mc:Ignorable="d"
        Title="UDP RPS Game" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Настройки подключения" Grid.Row="0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Server IP:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="TextBoxServerIP" Grid.Row="0" Grid.Column="1" Margin="5" Width="150" Text="127.0.0.1"/>

                <Label Content="Local Port:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="TextBoxLocalPort" Grid.Row="0" Grid.Column="3" Margin="5" Width="150" Text="5000"/>

                <Label Content="Remote Port:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="TextBoxRemotePort" Grid.Row="1" Grid.Column="1" Margin="5" Width="150" Text="5001"/>

                <Label Content="Role:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"/>
                <ComboBox x:Name="ComboBoxRole" Grid.Row="1" Grid.Column="3" Margin="5" Width="150" VerticalAlignment="Center">
                    <ComboBoxItem Content="Компьютер" IsSelected="True"/>
                    <ComboBoxItem Content="Человек"/>
                </ComboBox>

                <Button x:Name="ButtonStart" Content="Start" Grid.Row="2" Grid.ColumnSpan="4" HorizontalAlignment="Center" Margin="5" Width="150" Click="ButtonStart_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Ига" Padding="5" Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="5" Text="Количество матчей"/>
                <TextBox x:Name="TextBoxMatch" Grid.Row="0" Grid.Column="1" Text="5" Margin="5" TextAlignment="Center" IsEnabled="False"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Margin="5" Text="Количество игр"/>
                <TextBox x:Name="TextBoxGame" Grid.Row="0" Grid.Column="3" Text="3" Margin="5" TextAlignment="Center" IsEnabled="False"/>

                <TextBlock x:Name="TextBlockMode" Grid.Row="1" Grid.Column="0" Margin="5" FontWeight="Bold" Text="Модель: Человек - Компьютер"/>

                <Button x:Name="ButtonGameSettings" Grid.Row="1" Grid.Column="1" Margin="5" Grid.ColumnSpan="3" Width="300" 
                        Content="Предложить начать играть" Click="ButtonGameSettings_Click" IsEnabled="False"/>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                    <Button x:Name="ButtonRock" Content="Rock" Width="80" Margin="5" Click="ButtonRock_Click" IsEnabled="False"/>
                    <Button x:Name="ButtonPaper" Content="Paper" Width="80" Margin="5" Click="ButtonPaper_Click" IsEnabled="False"/>
                    <Button x:Name="ButtonScissors" Content="Scissors" Width="80" Margin="5" Click="ButtonScissors_Click" IsEnabled="False"/>
                    <Button x:Name="ButtonDrawnGame" Content="Ничья?" Width="80" Margin="155, 5, 5, 5" Click="ButtonDrawnGame_Click" IsEnabled="False"/>
                    <Button x:Name="ButtonDefeatGame" Content="Сдатиься?" Width="80" Margin="5" Click="ButtonDefeatGame_Click" IsEnabled="False"/>
                </StackPanel>

                <Grid Grid.Row="3" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox Grid.Row="0" x:Name="ListBoxMatch" Margin="5"/>
                    <Button Grid.Row="1" x:Name="ButtonResults" Content="Результаты" Margin="5" Height="20" Click="ButtonResults_Click" IsEnabled="False"/>
                </Grid>
                <Border Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="5" BorderBrush="Black" BorderThickness="1" Padding="3">
                    <TextBlock x:Name="TextBlockResultGame" Text="Результат игры, раунда и итоги"/>
                </Border>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
